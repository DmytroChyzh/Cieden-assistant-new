перейменуй в .env.local
встав ключі 


# OpenAI (Required for self-hosted CopilotKit)
OPENROUTER_API_KEY=
# Convex (Will be filled after convex init)
NEXT_PUBLIC_CONVEX_URL=
# ElevenLabs (For voice)
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=


# Development
NODE_ENV=development

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT= 

# Convex Auth (Required for JWT token generation)
JWT_PRIVATE_KEY=