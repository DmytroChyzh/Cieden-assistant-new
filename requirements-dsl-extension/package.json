{
  "name": "requirements-dsl",
  "displayName": "Requirements DSL",
  "description": "Syntax highlighting for Requirements DSL specification files (.spec) with controlled vocabulary",
  "version": "2.0.1",
  "publisher": "finpilot",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "requirements-dsl",
        "aliases": [
          "Requirements DSL",
          "requirements-dsl",
          "spec"
        ],
        "extensions": [
          ".spec"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "requirements-dsl",
        "scopeName": "source.requirements-dsl",
        "path": "./syntaxes/spec.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/finpilot/requirements-dsl"
  }
}
