{
  "name": "Requirements DSL",
  "scopeName": "source.requirements-dsl",
  "fileTypes": ["spec"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#section-headers"
    },
    {
      "include": "#change-markers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#state-flags"
    },
    {
      "include": "#data-sources"
    },
    {
      "include": "#boolean-values"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.requirements-dsl",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "section-headers": {
      "patterns": [
        {
          "name": "entity.name.section.define.requirements-dsl",
          "match": "^\\[(Define)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.state.requirements-dsl",
          "match": "^\\[(State)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.action.requirements-dsl",
          "match": "^\\[(Action)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.function.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.component.requirements-dsl",
          "match": "^\\[(Component)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.class.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.session.requirements-dsl",
          "match": "^\\[(Session)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.namespace.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.behavior.requirements-dsl",
          "match": "^\\[(Behavior)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.tag.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.configuration.requirements-dsl",
          "match": "^\\[(Configuration)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.constant.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.error.requirements-dsl",
          "match": "^\\[(Error)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.exception.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.integration.requirements-dsl",
          "match": "^\\[(Integration)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.interface.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.context.requirements-dsl",
          "match": "^\\[(Context)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.insight.requirements-dsl",
          "match": "^\\[(Insight)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "markup.italic.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.system.requirements-dsl",
          "match": "^\\[(System)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.namespace.requirements-dsl"
            }
          }
        },
        {
          "name": "entity.name.section.change.requirements-dsl",
          "match": "^\\[(Change)\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "keyword.control.requirements-dsl"
            },
            "2": {
              "name": "entity.name.tag.requirements-dsl"
            }
          }
        }
      ]
    },
    "change-markers": {
      "patterns": [
        {
          "name": "markup.inserted.requirements-dsl",
          "match": "^\\[\\+\\s+Add\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        },
        {
          "name": "markup.deleted.requirements-dsl",
          "match": "^\\[-\\s+Remove\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        },
        {
          "name": "markup.changed.requirements-dsl",
          "match": "^\\[~\\s+Modify\\s+([^\\]]+)\\]",
          "captures": {
            "1": {
              "name": "entity.name.type.requirements-dsl"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.requirements-dsl",
          "match": "^\\s*(Show if|Hide if|Execute if|Skip if|When|Occurs when|Apply to|Used for|Add to queue when|Flush queue when|Timer reset when|Lock acquisition|Lock release|Cleanup when|Pre-checks|Pre-cleanup|Pre-steps|Auto start|Auto end|Start conditions|Connection steps|Cleanup steps|Queue cleared when):"
        },
        {
          "name": "keyword.control.flow.requirements-dsl",
          "match": "^\\s*(Steps|On success|On error|On timeout|Response|Recovery|Detection|Processing|Behavior when|Special handling for|Purpose|Rationale|Benefits|Why it matters|Why order matters|Critical in|Note|Reason|Impact|Solution|Problem|Challenge|Trade-off|Result|Order):"
        },
        {
          "name": "keyword.other.requirements-dsl",
          "match": "^\\s*(Description|Type|Label|Style|Fields|Options|Storage|Default|Lifecycle|Reset when|Persistence|Source|Provider|Mode|Transport|Values|Timeout|Retry|Max duration|Idle timeout|Max queue size|Queue limit|Threshold|Update frequency|Enabled by|Conditions|Registration|Tool execution flow|Tool types|Example tools|Handler registration|Required props|Methods|Stream lifecycle|Exposed values|Exposed methods|Hook for consumption|Error if used outside provider|Code location|Cleanup|Safety|Prevention|Waiter object|Waiter collections|Add waiter when|Resolve waiters when|Reject waiters when|Protected by transition|Transition lifecycle|Transition serialization|History sources|Passing history to|Restart if needed|Queueing logic|State tracking|Timing|Prevention of duplicate starts|Lifecycle hooks|Special cases|Message type detection|Message types persisted|Tools registered|Props required|Behavior|Concurrent sessions|Cross-tab enforcement|Retry logic|Data received|State updates|Debug telemetry|Reset when|Lock data structure|Lock update|Staleness check|Text sessions|Cross-tab messages|Message handling|Cleanup on mount|Queues|Clear when|Timer start|Timer cancel|Data fields|Purpose|Usage|Apply to|Heartbeat|Stale session threshold):"
        },
        {
          "name": "storage.type.requirements-dsl",
          "match": "^\\s*(Data fields|Waiter object contains|Required environment variables|Text mode configuration|Voice mode configuration|Client tools):"
        }
      ]
    },
    "state-flags": {
      "patterns": [
        {
          "name": "variable.other.constant.state.requirements-dsl",
          "match": "\\bSTATE\\.[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "data-sources": {
      "patterns": [
        {
          "name": "variable.other.property.requirements-dsl",
          "match": "\\b(DB|Session|State|Props|API|SDK|Cross-tab|Lock|Current|Text|Voice|Conversation|Stream|Pending|Last|This|Active|Other|Message|Tool|Error|Connection|Mode)\\.[a-zA-Z_][a-zA-Z0-9_.]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
        }
      ]
    },
    "boolean-values": {
      "patterns": [
        {
          "name": "constant.language.boolean.requirements-dsl",
          "match": "\\b(yes|no|none|empty)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.requirements-dsl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.requirements-dsl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.requirements-dsl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.requirements-dsl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.requirements-dsl",
          "match": "\\b([0-9]+\\.?[0-9]*)\\s*(seconds|milliseconds|minutes|hours|days|ms|s|m|h|%)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.requirements-dsl",
          "match": "(>=|<=|>|<|:|→|\\+|\\-)"
        }
      ]
    }
  }
}
